rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized(email) {
      // Check if email exists in authorized_users collection (case insensitive)
      return exists(/databases/$(database)/documents/authorized_users/$(email.lower()));
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "palocontrerasyance@gmail.com" ||
        request.auth.token.email.lower() == "selahconsultingsas@gmail.com" ||
        isAuthorized(request.auth.token.email)
      );
    }

    match /authorized_users/{email} {
      // Allow any signed in user to get their own auth status
      allow get: if isSignedIn() && request.auth.token.email.lower() == email.lower();
      // Allow admins to manage list
      allow list: if isAdmin();
      // Allow hardcoded admins to write anything, or any user to sync their own if they are authenticated
      // Note: We might want to restrict this more, but for now it allows the code's auto-sync to work.
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == email.lower());
    }

    match /churches/{churchId} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /members/{memberId} {
        allow read, write: if isAdmin();
      }

      match /transactions/{transactionId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
